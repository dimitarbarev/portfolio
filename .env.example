# ─── Contact API (server only — never commit real values) ────────────────────
# Resend API key: https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# Your private inbox — never exposed to the website frontend
CONTACT_TO_EMAIL=your_private_email@example.com

# Verified sender address in Resend
CONTACT_FROM_EMAIL=Portfolio Contact <contact@yourdomain.com>

# Local API port (dev server only)
CONTACT_API_PORT=8787
